generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  firstName String?
  lastName  String?
  password  String
  role      String   @default("COLLABORATOR") // Roles: OWNER, COLLABORATOR
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Post {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String   // HTML content
  published  Boolean  @default(false)
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  tags       Tag[]
  views      PostView?
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  posts     Post[]
}

model SiteSettings {
  id                String   @id @default("singleton")
  title             String   @default("ExploreCMS")
  faviconUrl        String?
  headerTitle       String   @default("Explore. Create. Inspire.")
  headerDescription String   @default("Welcome to my personal corner of the internet. Here I share technical deep-dives and pieces of my life story.")
  sidebarAbout      String   @default("Discover articles on technology, creativity, and personal growth. Use the search or browse by tags to find what interests you.")
  navigationConfig  String   @default("[{\"id\":\"latest\",\"type\":\"latest\",\"label\":\"Latest\"},{\"id\":\"featured\",\"type\":\"featured\",\"label\":\"Featured\"}]")
  theme             String   @default("default")
  footerText        String   @default("")

  // Component System
  enabledComponents String   @default("[\"blog\"]") // JSON array of enabled component IDs
  defaultComponent  String   @default("blog")       // which component is served at /

  // Remote DB Config
  bunnyEnabled      Boolean  @default(false)
  bunnyUrl          String?
  bunnyToken        String?

  // Bunny Storage Config
  bunnyStorageEnabled   Boolean  @default(false)
  bunnyStorageRegion    String?  // e.g., "fsn1", "ny", "sg"
  bunnyStorageZoneName  String?  // e.g., "my-zone"
  bunnyStorageApiKey    String?
  bunnyStorageUrl       String?  // CDN URL like https://my-zone.b-cdn.net

  updatedAt         DateTime @updatedAt
}

model Project {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  tagline     String         @default("")
  content     String         @default("") // rich HTML content
  coverImage  String?
  status      String         @default("completed") // completed, in_progress, archived
  featured    Boolean        @default(false)
  published   Boolean        @default(false)
  githubUrl   String?
  liveUrl     String?
  techTags    String         @default("[]") // JSON array of tech strings
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  images      ProjectImage[]
}

model ProjectImage {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  caption   String  @default("")
  order     Int     @default(0)
}

model PhotoAlbum {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String   @default("")
  coverImage  String?
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  photos      Photo[]
}

model Photo {
  id           String     @id @default(cuid())
  albumId      String
  album        PhotoAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  title        String     @default("")
  description  String     @default("")
  url          String
  location     String     @default("")
  takenAt      DateTime?
  order        Int        @default(0)
  featured     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model PopupConfig {
  id          String   @id @default("singleton")
  enabled     Boolean  @default(false)
  title       String   @default("")
  content     String   @default("")
  displayMode String   @default("once") // "once" = once per visitor, "always" = every page load
  updatedAt   DateTime @updatedAt
}

model SiteAnalytics {
  id          String   @id @default("singleton")
  totalViews  Int      @default(0)
  uniqueViews Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model PostView {
  id          String   @id @default(cuid())
  postId      String   @unique
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  totalViews  Int      @default(0)
  uniqueViews Int      @default(0)
  updatedAt   DateTime @updatedAt
}
